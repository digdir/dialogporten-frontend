{
  "name": "bff-frontend-poc",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit -w",
    "lint": "",
    "lint:fix": "",
    "build:docker": "docker build -f ./Dockerfile -t bff-frontend-poc ../..",
    "run:docker": "docker run -it -p 80:80 bff-frontend-poc"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.8.4",
    "@tanstack/react-query-devtools": "^5.7.4",
    "axios": "^1.5.0",
    "jest": "^29.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.16.0",
    "typescript": "^4.9.5",
    "vite": "^5.0.8",
    "vitest": "^1.2.2"
  },
  "devDependencies": {
    "@swc/core": "^1.3.84",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/css-modules": "1.0.4",
    "@types/react": "18.2.34",
    "@types/react-dom": "18.2.14",
    "@types/react-query": "^1.2.9",
   "typescript-plugin-css-modules": "^5.0.1"
  },
  "jest": {
    "moduleNameMapper": {
      "axios": "axios/dist/node/axios.cjs"
    }
  }
}
