{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "packages/bff/node_modules/**"]
    },
    "build:bff-types-generated": {
      "dependsOn": ["build:@digdir/dialogporten-node-logger", "install:bff"],
      "outputs": ["generated/**"],
      "cache": false
    },
    "build:@digdir/dialogporten-node-logger": {
      "outputs": ["packages/node-logger/dist/**"],
      "cache": false
    },
    "build:bff": {
      "env": ["BASEURL", "URL"],
      "dependsOn": ["build:@digdir/dialogporten-node-logger", "build:bff-types-generated"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "outputs": [],
      "cache": false
    },
    "typecheck": {
      "outputs": [],
      "cache": false
    },
    "build:docker": {
      "outputs": [],
      "cache": false
    }
  }
}
